@model List<Category>

<h1>List of Categories</h1>

<table class="table table-bordered table-striped">
	<thead>
		<tr>
			<th>Name</th>
			<th>Description</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var eachCategory in Model)
		{
			<tr>
				<td>@eachCategory.Name</td>
				<td>@eachCategory.Description</td>
				
				<td>
					<a asp-controller="Category" asp-action="Edit" asp-route-id="@eachCategory.CategoryId">Edit</a>
					|
					<a asp-controller="Category" asp-action="Details" asp-route-id="@eachCategory.CategoryId">Details</a>
					|
					<a asp-controller="Category" asp-action="Delete" asp-route-id="@eachCategory.CategoryId">Delete</a>
				</td>
			</tr>
		}
	</tbody>

	</table>

	<div class="col-md-12 text-end">

		<a class="btn btn-outline-primary" asp-controller="Category" asp-action="Create">Add New Category </a>

	</div>
