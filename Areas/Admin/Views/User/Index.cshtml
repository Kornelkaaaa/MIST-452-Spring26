@model List<BooksSpring26.ApplicationUser>
@{
    var adminIds = ViewData["AdminIds"] as HashSet<string> ?? new HashSet<string>();
}

<div class="card shadow border-1 my-4">
    <div class="card-header bg-primary text-white py-3">
        <h2>User Management</h2>
    </div>
    <div class="card-body p-4">

        <form method="get" asp-area="Admin" asp-controller="User" asp-action="Index" class="mb-3">
            <div class="input-group">
                <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]" class="form-control" placeholder="Search by name, email, or username..." />
                <button type="submit" class="btn btn-primary">Search</button>
                @if (!string.IsNullOrWhiteSpace(ViewData["SearchTerm"] as string))
                {
                    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="User" asp-action="Index">Clear</a>
                }
            </div>
        </form>

        @if (Model.Count == 0)
        {
            <div class="alert alert-info">No users found.</div>
        }
        else
        {
            <table class="table table-bordered table-striped table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>City</th>
                        <th>State</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var isLocked = user.LockoutEnd != null && user.LockoutEnd > DateTime.Now;
                        var isAdmin = adminIds.Contains(user.Id);
                        <tr>
                            <td>@user.Name</td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td>@user.City</td>
                            <td>@user.State</td>
                            <td>
                                @if (isAdmin)
                                {
                                    <span class="badge bg-primary">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Customer</span>
                                }
                            </td>
                            <td>
                                @if (isLocked)
                                {
                                    <span class="badge bg-danger">Locked</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                            <td>
                                <a class="btn btn-sm btn-info" asp-area="Admin" asp-controller="User" asp-action="Details" asp-route-id="@user.Id">Details</a>
                                <form method="post" asp-area="Admin" asp-controller="User" asp-action="ToggleAdmin" asp-route-id="@user.Id" class="d-inline">
                                    @if (isAdmin)
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Revoke Admin</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-primary">Make Admin</button>
                                    }
                                </form>
                                <form method="post" asp-area="Admin" asp-controller="User" asp-action="LockUnlock" asp-route-id="@user.Id" class="d-inline">
                                    @if (isLocked)
                                    {
                                        <button type="submit" class="btn btn-sm btn-success">Unlock</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-warning">Lock</button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
