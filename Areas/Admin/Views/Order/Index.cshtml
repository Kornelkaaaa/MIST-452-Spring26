@model IEnumerable<Order>

<div claass="card shadow border-1 my-4">
    <div class="card pt-2 pb-2">
        <h1>Order List</h1>
    </div>
</div>

<div class="card-body p-4">
    <table class="table table-bordered table-striped table-hover rounded-3">
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Order Date</th>
                <th>Customer Name</th>
                <th>Email</th>
                <th>Total Amount</th>
            </tr>
        </thead>
    </table>
</div>