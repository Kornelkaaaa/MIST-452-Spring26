@model Book

<div class="card shadow border-1 my-4">
    <div class="card-header bg-primary text-white py-3">
        <h2>Book Details</h2>
    </div>
    <div class="card-body p-4">
        <div class="row">
            <div class="col-md-3">
                @if (!string.IsNullOrEmpty(Model.ImgUrl))
                {
                    <img src="@Model.ImgUrl" class="img-fluid rounded" alt="@Model.Title" />
                }
            </div>
            <div class="col-md-9">
                <dl class="row">
                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">@Model.Title</dd>

                    <dt class="col-sm-3">Author</dt>
                    <dd class="col-sm-9">@Model.Author</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3">Price</dt>
                    <dd class="col-sm-9">@Model.Price.ToString("c")</dd>

                    <dt class="col-sm-3">Category</dt>
                    <dd class="col-sm-9">@Model.category?.Name</dd>
                </dl>

                <a class="btn btn-secondary" asp-area="Admin" asp-controller="Book" asp-action="Index">Back to list</a>
                <a class="btn btn-primary" asp-area="Admin" asp-controller="Book" asp-action="Edit" asp-route-id="@Model.BookId">Edit</a>
            </div>
        </div>
    </div>
</div>
