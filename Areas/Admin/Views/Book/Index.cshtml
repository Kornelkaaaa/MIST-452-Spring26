@model List<Book>

<h1>List of Books</h1>

<table class="table table-bordered table-striped">
	<thead>
		<tr>
			<th>Name</th>
			<th>Description</th>
			<th>Category</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var eachBook in Model)
		{
			<tr>
				<td>@eachBook.Title</td>
				<td>@eachBook.Description</td>
				<td>@eachBook.category?.Name</td>

				<td>
					<a asp-controller="Book" asp-action="Edit" asp-route-id="@eachBook.BookId">Edit</a>
					|
					<a asp-controller="Book" asp-action="Details" asp-route-id="@eachBook.BookId">Details</a>
					|
					<a asp-controller="Book" asp-action="Delete" asp-route-id="@eachBook.BookId">Delete</a>
				</td>
			</tr>
		}
	</tbody>

</table>

<div class="col-md-12 text-end">

	<a class="btn btn-outline-primary" asp-controller="Book" asp-action="Create">Add New Book </a>

</div>
