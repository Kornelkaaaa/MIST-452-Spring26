@model Book

<div class="card shadow border-1 my-4">
    <div class="card-header bg-danger text-white py-3">
        <h2>Delete Book</h2>
    </div>
    <div class="card-body p-4">
        <h4>Are you sure you want to delete this book?</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Author</dt>
            <dd class="col-sm-9">@Model.Author</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.Price.ToString("c")</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.category?.Name</dd>
        </dl>

        <form method="post" asp-area="Admin" asp-controller="Book" asp-action="Delete" asp-route-id="@Model.BookId" class="d-inline">
            <button type="submit" class="btn btn-danger">Delete</button>
        </form>
        <a class="btn btn-secondary" asp-area="Admin" asp-controller="Book" asp-action="Index">Cancel</a>
    </div>
</div>
