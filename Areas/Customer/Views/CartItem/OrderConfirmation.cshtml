@model int
@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container my-5">
    <div class="card shadow-sm text-center mx-auto" style="max-width: 540px;">
        <div class="card-body p-5">
            <div style="font-size:4rem;">✅</div>
            <h2 class="fw-bold mt-3">Thank you for your order!</h2>
            <p class="text-muted">Your payment was successful and your order has been placed.</p>
            <div class="alert alert-info mt-4">
                Order Number: <strong>#@Model</strong>
            </div>
            <a class="btn btn-primary mt-3" asp-area="Customer" asp-controller="Home" asp-action="Index">Continue Shopping</a>
        </div>
    </div>
</div>
