@model ShoppingCartVM
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-header py-3">
            <h3 class="mb-0">Shopping Cart</h3>
        </div>
        <div class="card-body">
            @if (!Model.CartItems.Any())
            {
                <div class="alert alert-info text-center my-3">
                    Your cart is empty. <a asp-area="Customer" asp-controller="Home" asp-action="Index">Browse books</a>
                </div>
            }
            else
            {
                @foreach (var item in Model.CartItems)
                {
                    <div class="row align-items-center py-3 border-bottom">
                        <div class="col-2 text-center">
                            @if (!string.IsNullOrEmpty(item.Book.ImgUrl))
                            {
                                <img src="@item.Book.ImgUrl" class="img-fluid rounded" style="max-height:120px;" alt="@item.Book.Title" />
                            }
                        </div>
                        <div class="col-5">
                            <h6 class="fw-bold mb-1">@item.Book.Title</h6>
                            <p class="text-muted small mb-0">@item.Book.Author</p>
                        </div>
                        <div class="col-2 text-center">
                            <div class="text-muted small">Unit price</div>
                            <div class="fw-semibold">@item.Book.Price.ToString("c")</div>
                        </div>
                        <div class="col-2 text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="DecrementByOne" asp-route-id="@item.CartItemId" class="btn btn-sm btn-outline-secondary">−</a>
                                <span class="btn btn-sm btn-light disabled">@item.Quantity</span>
                                <a asp-action="IncrementByOne" asp-route-id="@item.CartItemId" class="btn btn-sm btn-outline-secondary">+</a>
                            </div>
                            <div class="small text-muted mt-1">@((item.Book.Price * item.Quantity).ToString("c"))</div>
                        </div>
                        <div class="col-1 text-end">
                            <a asp-action="RemoveFromCart" asp-route-id="@item.CartItemId" class="btn btn-sm btn-outline-danger" title="Remove">×</a>
                        </div>
                    </div>
                }

                <div class="row mt-4">
                    <div class="col-md-6 offset-md-6 text-end">
                        <h5>Order Total: <span class="fw-bold">@Model.Order.OrderTotal.ToString("c")</span></h5>
                        <a asp-action="ReviewOrder" class="btn btn-primary mt-2">Review the Order</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
