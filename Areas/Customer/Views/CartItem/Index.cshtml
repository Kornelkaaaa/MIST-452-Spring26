@model ShoppingCartVM

<form method="post">
    <div class="cart text-center rounded shadow">
        <div class="row m-3 px-4">

            <div class="col-12 rounded py-2 my-3">
                <p class="card-title text-start text-warning h3">
                    Shopping Cart
                </p>
            </div>

            <div class="col-12">
                @foreach (var item in Model.CartItems)
                {
                    <div class="row border-bottom my-3 align-items-center">

                        <!-- Image -->
                        <div class="col-2 text-center">
                            <img src="@item.Book.ImgUrl"
                                 class="img-fluid rounded"
                                 style="max-width:150px;" />
                        </div>

                        <!-- Title + Description -->
                        <div class="col-6 text-start">
                            <h5 class="text-uppercase text-secondary">
                                @item.Book.Title
                            </h5>
                            <p class="text-muted">
                                @item.Book.Description
                            </p>
                        </div>

                        <!-- Price -->
                        <div class="col-2 text-end">
                            <h6>
                                @item.Book.Price.ToString("C") x @item.Quantity
                            </h6>
                            <br />
                            Subtotal: @item.Subtotal.ToString("c")
                        </div>

                        <div class="col-1">
                            <div class="btn-group">
                                <a asp-action="IncrementByOne" class="btn btn-outline-primary py-2" asp-route-id="@item.CartItemId">
                                    +
                                </a>
                                &nbsp;
                                <a asp-action="DecrementByOne" class="btn btn-outline-primary py-2" asp-route-id="@item.CartItemId">
                                    -
                                </a>
                            </div>
                        </div>
                        <div class="col-1">
                            <a asp-action="RemoverFromCart"
                               class="btn btn-warning"
                               asp-route-id="@item.CartItemId">
                               Remove
                            </a>
                        </div>
                    </div>
                }
            </div>
                <div class="col-12 text-end">
                    Order Total : @Model.Order.OrderTotal.ToString("c")
                </div>
                <div>
                    <a asp-action="ReviewOrder" class="btn btn-warning py-2">Review the Order</a>
                </div>
        </div>
        
    </div>
</form>