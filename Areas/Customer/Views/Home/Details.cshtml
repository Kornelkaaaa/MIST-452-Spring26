@model CartItem
@{
    ViewData["Title"] = Model.Book.Title;
}

<div class="container my-4 book-detail">
    <a class="back-link" asp-area="Customer" asp-controller="Home" asp-action="Index">&larr; Catalog</a>

    <div class="row g-5 mt-1">
        <div class="col-md-4 col-lg-3">
            <div class="book-cover detail-cover">
                @if (!string.IsNullOrEmpty(Model.Book.ImgUrl))
                {
                    <img src="@Model.Book.ImgUrl" alt="@Model.Book.Title" />
                }
                else
                {
                    <span class="no-cover">no cover</span>
                }
            </div>
        </div>
        <div class="col-md-8 col-lg-9">
            @if (Model.Book.category != null)
            {
                <div class="book-meta-cat">@Model.Book.category.Name</div>
            }
            <h1 class="detail-title">@Model.Book.Title</h1>
            <p class="detail-author">by @Model.Book.Author</p>
            <p class="detail-desc">@Model.Book.Description</p>

            <div class="detail-buy">
                <div class="detail-price">@Model.Book.Price.ToString("c")</div>

                <form asp-action="AddToCart" method="post" class="d-inline-flex align-items-center gap-2 mt-2">
                    <input type="hidden" asp-for="@Model.BookId" />
                    <label class="text-muted small mb-0">Qty</label>
                    <input type="number" asp-for="@Model.Quantity" min="1" class="form-control" style="width:80px" />
                    <button type="submit" class="btn btn-primary">Add to Cart</button>
                </form>
            </div>
        </div>
    </div>
</div>
