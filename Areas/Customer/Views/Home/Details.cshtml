@model CartItem
@{
    ViewData["Title"] = Model.Book.Title;
}

<div class="container my-4">
    <a class="text-muted small" asp-area="Customer" asp-controller="Home" asp-action="Index">&larr; Back to all books</a>

    <div class="card mt-3 shadow-sm">
        <div class="row g-0">
            <div class="col-md-4 book-img-wrap" style="height:auto; min-height:400px; border-radius: var(--radius) 0 0 var(--radius);">
                @if (!string.IsNullOrEmpty(Model.Book.ImgUrl))
                {
                    <img src="@Model.Book.ImgUrl" alt="@Model.Book.Title" />
                }
                else
                {
                    <span class="placeholder">📖</span>
                }
            </div>
            <div class="col-md-8">
                <div class="card-body p-4 d-flex flex-column h-100">
                    @if (Model.Book.category != null)
                    {
                        <span class="book-category mb-2">@Model.Book.category.Name</span>
                    }
                    <h1 class="fw-bold">@Model.Book.Title</h1>
                    <p class="text-muted mb-3">by @Model.Book.Author</p>
                    <p class="lead">@Model.Book.Description</p>

                    <div class="mt-auto">
                        <h2 class="fw-bold mb-3">@Model.Book.Price.ToString("c")</h2>

                        <form asp-action="AddToCart" method="post" class="d-inline-flex align-items-center gap-2">
                            <input type="hidden" asp-for="@Model.BookId" />
                            <label class="text-muted small mb-0">Qty</label>
                            <input type="number" asp-for="@Model.Quantity" min="1" class="form-control" style="width:90px" />
                            <button type="submit" class="btn btn-primary">Add to Cart</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
