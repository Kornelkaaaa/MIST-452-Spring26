@{
    ViewData["Title"] = "Home Page";
}
@model List<Book>

<div class="container">
    <div class="text-center mt-4">
        <h1 class="fw-bold">Discover Your Next Read</h1>
        <p class="text-muted">Browse our curated collection of books across every genre.</p>
    </div>

    <form method="get" asp-area="Customer" asp-controller="Home" asp-action="Index" class="search-bar">
        <div class="d-flex">
            <div class="input-group">
                <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]" class="form-control" placeholder="Search by title, author, or category..." />
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(ViewData["SearchTerm"] as string))
            {
                <a class="btn btn-outline-secondary" asp-area="Customer" asp-controller="Home" asp-action="Index">Clear</a>
            }
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info text-center">No books found.</div>
    }

    <div class="row book-grid mt-2">
        @foreach (var eachBook in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card book-card">
                    <div class="book-img-wrap">
                        @if (!string.IsNullOrEmpty(eachBook.ImgUrl))
                        {
                            <img src="@eachBook.ImgUrl" alt="@eachBook.Title" />
                        }
                        else
                        {
                            <span class="placeholder">📖</span>
                        }
                    </div>
                    <div class="card-body">
                        @if (eachBook.category != null)
                        {
                            <span class="book-category">@eachBook.category.Name</span>
                        }
                        <h5 class="book-title">@eachBook.Title</h5>
                        <div class="book-author">by @eachBook.Author</div>
                        <p class="book-desc">@eachBook.Description</p>
                        <div class="book-price">@eachBook.Price.ToString("c")</div>
                        <a class="btn btn-outline-primary w-100" asp-controller="Home" asp-action="Details" asp-route-id="@eachBook.BookId">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
