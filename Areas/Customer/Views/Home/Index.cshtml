@{
    ViewData["Title"] = "Home Page";
}

@model List<Book>

    <div class="container">
        <form method="get" asp-area="Customer" asp-controller="Home" asp-action="Index" class="my-3">
            <div class="input-group">
                <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]" class="form-control" placeholder="Search by title, author, or category..." />
                <button type="submit" class="btn btn-primary">Search</button>
                @if (!string.IsNullOrWhiteSpace(ViewData["SearchTerm"] as string))
                {
                    <a class="btn btn-outline-secondary" asp-area="Customer" asp-controller="Home" asp-action="Index">Clear</a>
                }
            </div>
        </form>

        @if (Model.Count == 0)
        {
            <div class="alert alert-info">No books found.</div>
        }

        <div class="row">
            @foreach( var eachBook in Model)
            {
                <div class="col-md-3 mb-4">
                    <div>
                        <div class="card shadow-sm h-100 d-flex flex-column w-100">
                        <img class="card-img-top" src="@eachBook.ImgUrl" style="height:200px; object-fit:cover" />
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title" style="color:deeppink">@eachBook.Title</h5>
							    <p class="card-text text-muted">
                                    @eachBook.Author 
								    <br />
								    @eachBook.Description
                                    <br />
								    @eachBook.category?.Name
                                    <br />
                                </p>
                                <div class="mt-auto">
                                    <p class="fw-bold mb-2">
									$@eachBook.Price.ToString("0.00")
                                    </p>
                                </div>
							    <a class="btn btn-outline-primary w-100" asp-controller="Home" asp-action="Details" asp-route-id="@eachBook.BookId">View Details</a>

                               
                            </div>
                        </div>
                    </div>


                </div>

        }
            
		</div>
    </div>