@{
    ViewData["Title"] = "Catalog";
    var term = ViewData["SearchTerm"] as string;
}
@model List<Book>

<div class="container">
    <div class="catalog-header">
        <div>
            <h1>@(string.IsNullOrWhiteSpace(term) ? "Catalog" : $"Results for “{term}”")</h1>
            <div class="catalog-meta">
                @Model.Count @(Model.Count == 1 ? "title" : "titles")
            </div>
        </div>
        <form method="get" asp-area="Customer" asp-controller="Home" asp-action="Index" class="catalog-search">
            <input type="text" name="searchTerm" value="@term" placeholder="Search title, author, category" />
            <button type="submit" class="btn btn-outline-primary btn-sm">Search</button>
            @if (!string.IsNullOrWhiteSpace(term))
            {
                <a asp-area="Customer" asp-controller="Home" asp-action="Index">clear</a>
            }
        </form>
    </div>

    @if (Model.Count == 0)
    {
        <p class="text-muted">Nothing matched. Try a different search.</p>
    }

    <div class="row book-grid">
        @foreach (var book in Model)
        {
            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <a class="book-tile" asp-controller="Home" asp-action="Details" asp-route-id="@book.BookId">
                    <div class="book-cover">
                        @if (!string.IsNullOrEmpty(book.ImgUrl))
                        {
                            <img src="@book.ImgUrl" alt="" />
                        }
                        else
                        {
                            <span class="no-cover">no cover</span>
                        }
                    </div>
                    @if (book.category != null)
                    {
                        <div class="book-meta-cat">@book.category.Name</div>
                    }
                    <h2 class="book-title">@book.Title</h2>
                    <div class="book-author">@book.Author</div>
                    <div class="book-price">@book.Price.ToString("c")</div>
                </a>
            </div>
        }
    </div>
</div>
